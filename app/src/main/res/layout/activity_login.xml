<?xml version="1.0" encoding="utf-8"?>
<ScrollView xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:background="@color/bg"
    android:fillViewport="true">

    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:orientation="vertical"
        android:padding="24dp">

        <!-- Header -->
        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="200dp"
            android:orientation="vertical"
            android:gravity="center"
            android:background="@drawable/header_bg"
            android:layout_marginBottom="32dp">

            <TextView
                android:layout_width="60dp"
                android:layout_height="60dp"
                android:gravity="center"
                android:text="ENS"
                android:textColor="@color/accent2"
                android:textSize="14sp"
                android:textStyle="bold"
                android:background="@drawable/badge_bg"
                android:layout_marginBottom="16dp"/>

            <TextView
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="École Normale Supérieure"
                android:textColor="@color/text_primary"
                android:textSize="20sp"
                android:textStyle="bold"
                android:layout_marginBottom="6dp"/>

            <TextView
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="Marrakech — Gestion des visiteurs"
                android:textColor="@color/text_subtle"
                android:textSize="12sp"/>
        </LinearLayout>

        <!-- Title -->
        <TextView
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="Connexion"
            android:textSize="28sp"
            android:textColor="@color/text_primary"
            android:textStyle="bold"
            android:layout_marginBottom="6dp"/>

        <TextView
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="Choisissez votre profil d'accès"
            android:textSize="13sp"
            android:textColor="@color/text_muted"
            android:layout_marginBottom="24dp"/>

        <!-- Profile Grid -->
        <GridLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:columnCount="2"
            android:layout_marginBottom="24dp">

            <Button
                android:id="@+id/btnAdmin"
                android:layout_width="0dp"
                android:layout_height="72dp"
                android:layout_columnWeight="1"
                android:layout_margin="5dp"
                android:text="Admin&#10;Accès complet"
                android:textSize="11sp"
                android:textColor="@color/text_primary"
                android:backgroundTint="@color/surface"
                style="@style/Widget.MaterialComponents.Button.OutlinedButton"
                app:strokeColor="@color/border_light"
                app:cornerRadius="12dp"/>

            <Button
                android:id="@+id/btnAgent"
                android:layout_width="0dp"
                android:layout_height="72dp"
                android:layout_columnWeight="1"
                android:layout_margin="5dp"
                android:text="Agent&#10;Check-in/out"
                android:textSize="11sp"
                android:textColor="@color/text_primary"
                android:backgroundTint="@color/surface"
                style="@style/Widget.MaterialComponents.Button.OutlinedButton"
                app:strokeColor="@color/border_light"
                app:cornerRadius="12dp"/>

            <Button
                android:id="@+id/btnHost"
                android:layout_width="0dp"
                android:layout_height="72dp"
                android:layout_columnWeight="1"
                android:layout_margin="5dp"
                android:text="Hôte&#10;Gestion invités"
                android:textSize="11sp"
                android:textColor="@color/text_primary"
                android:backgroundTint="@color/surface"
                style="@style/Widget.MaterialComponents.Button.OutlinedButton"
                app:strokeColor="@color/border_light"
                app:cornerRadius="12dp"/>

            <Button
                android:id="@+id/btnVisitor"
                android:layout_width="0dp"
                android:layout_height="72dp"
                android:layout_columnWeight="1"
                android:layout_margin="5dp"
                android:text="Visiteur&#10;Suivi visites"
                android:textSize="11sp"
                android:textColor="@color/text_primary"
                android:backgroundTint="@color/surface"
                style="@style/Widget.MaterialComponents.Button.OutlinedButton"
                app:strokeColor="@color/border_light"
                app:cornerRadius="12dp"/>
        </GridLayout>

        <!-- Email -->
        <com.google.android.material.textfield.TextInputLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:hint="Email"
            android:layout_marginBottom="14dp"
            app:boxBackgroundColor="@color/surface"
            app:boxStrokeColor="@color/border_light"
            app:hintTextColor="@color/text_subtle"
            app:boxCornerRadiusTopStart="10dp"
            app:boxCornerRadiusTopEnd="10dp"
            app:boxCornerRadiusBottomStart="10dp"
            app:boxCornerRadiusBottomEnd="10dp"
            style="@style/Widget.MaterialComponents.TextInputLayout.OutlinedBox">
            <com.google.android.material.textfield.TextInputEditText
                android:id="@+id/etEmail"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:inputType="textEmailAddress"
                android:textColor="@color/text_primary"/>
        </com.google.android.material.textfield.TextInputLayout>

        <!-- Password -->
        <com.google.android.material.textfield.TextInputLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:hint="Mot de passe"
            android:layout_marginBottom="12dp"
            app:passwordToggleEnabled="true"
            app:passwordToggleTint="@color/text_subtle"
            app:boxBackgroundColor="@color/surface"
            app:boxStrokeColor="@color/border_light"
            app:hintTextColor="@color/text_subtle"
            app:boxCornerRadiusTopStart="10dp"
            app:boxCornerRadiusTopEnd="10dp"
            app:boxCornerRadiusBottomStart="10dp"
            app:boxCornerRadiusBottomEnd="10dp"
            style="@style/Widget.MaterialComponents.TextInputLayout.OutlinedBox">
            <com.google.android.material.textfield.TextInputEditText
                android:id="@+id/etPassword"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:inputType="textPassword"
                android:textColor="@color/text_primary"/>
        </com.google.android.material.textfield.TextInputLayout>

        <!-- Error -->
        <TextView
            android:id="@+id/tvError"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:text=""
            android:textColor="@color/accent_red"
            android:textSize="13sp"
            android:background="@drawable/error_bg"
            android:padding="10dp"
            android:layout_marginBottom="12dp"
            android:visibility="gone"/>

        <!-- Login Button -->
        <Button
            android:id="@+id/btnLogin"
            android:layout_width="match_parent"
            android:layout_height="52dp"
            android:text="Se connecter"
            android:textColor="@color/text_primary"
            android:textStyle="bold"
            android:textSize="15sp"
            android:backgroundTint="@color/accent"
            app:cornerRadius="12dp"
            android:layout_marginBottom="16dp"
            style="@style/Widget.MaterialComponents.Button"/>

        <!-- Forgot Password -->
        <TextView
            android:id="@+id/tvForgotPassword"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:text="Mot de passe oublié ?"
            android:textColor="@color/accent2"
            android:textSize="13sp"
            android:gravity="center"
            android:clickable="true"
            android:focusable="true"
            android:layout_marginBottom="24dp"/>

    </LinearLayout>
</ScrollView>
